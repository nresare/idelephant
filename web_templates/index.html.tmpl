<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>idElephant signup and login page</title>
<link rel="stylesheet" href="/static/index.css">
</head>
<body>
<main>
<section class="hero">
<p class="eyebrow">Passkey identity provider</p>
{{#if identity}}
<h1>Welcome back</h1>
<p class="lede">You are signed in as <strong>{{identity.email}}</strong>.</p>
{{else}}
<h1>idElephant</h1>
<p class="lede">Sign in with a passkey to continue to your identity provider account.</p>
{{/if}}
</section>

<section class="panel" aria-labelledby="session-title">
<div id="error-box" class="error-box" hidden role="alert" aria-live="polite">
<button id="error-close" class="error-close" type="button" aria-label="Close error message">x</button>
<div id="error-message"></div>
</div>

<h2 id="session-title">{{#if identity}}Current session{{else}}Login{{/if}}</h2>
{{#if identity}}
<p class="muted">Use this account for pending authorization requests, or log out to switch identity.</p>
<p class="action-row"><input id="logout" type="submit" value="log out"></p>
{{else}}
<p class="muted">Your browser will ask for the passkey associated with this service.</p>
<p class="action-row"><input id="authenticate" type="submit" value="log in"></p>
{{/if}}
</section>
</main>
<script src="/static/script.js"></script>
<script>
window.idElephantPendingAuthorization = {{#if pending_authorization}}true{{else}}false{{/if}};
document.getElementById("error-close").addEventListener("click", hideError)
{{#if identity}}
document.getElementById("logout").addEventListener("click", logout)
{{else}}
document.getElementById("authenticate").addEventListener("click", authenticate)
{{/if}}
</script>
</body>
</html>
